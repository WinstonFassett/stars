{
  "name": "stars-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "syncdata": "node -e \"const fs=require('fs');fs.mkdirSync('public/data',{recursive:true});fs.copyFileSync('../stars.csv','public/data/stars.csv')\"",
    "predev": "npm run syncdata",
    "dev": "ASTRO_DEV_BACKGROUND=1 portless run astro dev",
    "prebuild": "npm run syncdata",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@leeoniya/ufuzzy": "^1.0.19",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "marked-highlight": "^2.2.4",
    "mermaid": "^11.16.0",
    "papaparse": "^5.5.4",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/svelte": "^9.0.0",
    "@types/papaparse": "^5.5.2",
    "svelte": "^5.56.4"
  }
}
